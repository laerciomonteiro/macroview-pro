# =============================================================================
# MacroView Pro - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values
# DO NOT commit actual API keys to version control!
# =============================================================================

# =============================================================================
# Required API Keys
# =============================================================================

# Gemini API Key (required for AI market analysis)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# Optional API Keys
# =============================================================================

# Twelve Data API Key (optional - for additional commodity data)
# Get your key at: https://twelvedata.com/
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# Market Data API Credentials (optional - for premium market data)
# MARKET_API_KEY=your_market_api_key_here
# MARKET_API_SECRET=your_market_api_secret_here